<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ezria.lifetrackr.Mapper.UserMapper">
    <update id="updateUser">
        UPDATE user
        <set>
            <if test="dto.username != null and dto.username != ''">
                username = #{dto.username},
            </if>
            <if test="dto.password != null and dto.password != ''">
                password = #{dto.password},
            </if>
            <if test="dto.avatar != null and dto.avatar != ''">
                avatar = #{dto.avatar},
            </if>
            <if test="dto.Introduction != null and dto.Introduction != ''">
                Introduction = #{dto.Introduction},
            </if>
            <if test="dto.phone != null">
                phone = #{dto.phone},
            </if>
            <if test="dto.Email != null and dto.Email != ''">
                Email = #{dto.Email},
            </if>
        </set>
        WHERE id = #{userId}
    </update>
</mapper>